# Server Configuration
NODE_ENV=development
PORT=3000

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/smart-cafe

# JWT Configuration
JWT_SECRET=smart-cafe-secret-key-dev-only-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=smart-cafe-refresh-secret-dev-only
JWT_REFRESH_EXPIRES_IN=30d

# Email Configuration (for OTP) - Mock in development
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Smart Cafe <noreply@smartcafe.com>

# OTP Configuration
OTP_EXPIRY_MINUTES=10

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
